{
  "name": "@toride/codegen",
  "version": "0.2.0",
  "description": "Code generation tools for Toride authorization engine",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "toride-codegen": "./dist/cli.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "nx": {
    "tags": ["type:codegen"]
  },
  "dependencies": {
    "toride": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["authorization", "codegen", "toride"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/toride-auth/toride"
  }
}
