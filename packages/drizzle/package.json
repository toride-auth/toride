{
  "name": "@toride/drizzle",
  "version": "0.0.1",
  "description": "Drizzle ORM integration for Toride authorization engine",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "nx": {
    "tags": ["type:integration"]
  },
  "dependencies": {
    "toride": "workspace:*"
  },
  "peerDependencies": {
    "drizzle-orm": ">=0.29.0"
  },
  "peerDependenciesMeta": {
    "drizzle-orm": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["authorization", "drizzle", "toride"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/toride-auth/toride"
  }
}
